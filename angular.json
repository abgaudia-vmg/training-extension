{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "extension-training": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": {
              "base": "dist/extension-training",
              "browser": ""
            },
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": [
              "src/styles.scss",
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css"
            ],
            "scripts": []
          },
          "configurations": {
            "prod": {
              "optimization": {
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                }
              },
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "**/*",
                  "input": "src/icons/prod",
                  "output": "assets/icons"
                },
                "src/favicon.ico",
                "src/manifest.json",
                "src/background.js",
                "src/content.js"
              ],
              "scripts": [
                {
                  "input": "src/environments/environment.prod.js",
                  "bundleName": "environment",
                  "inject": false
                }
              ]
            },
            "dev": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "**/*",
                  "input": "src/icons/dev",
                  "output": "assets/icons"
                },
                "src/favicon.ico",
                "src/manifest.json",
                "src/background.js",
                "src/content.js"
              ],
              "scripts": [
                {
                  "input": "src/environments/environment.dev.js",
                  "bundleName": "environment",
                  "inject": false
                }
              ]
            },
            "qa": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.qa.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "**/*",
                  "input": "src/icons/qa",
                  "output": "assets/icons"
                },
                "src/favicon.ico",
                "src/manifest.json",
                "src/background.js",
                "src/content.js"
              ],
              "scripts": [
                {
                  "input": "src/environments/environment.qa.js",
                  "bundleName": "environment",
                  "inject": false
                }
              ]
            },
            "staging": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.staging.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "**/*",
                  "input": "src/icons/staging",
                  "output": "assets/icons"
                },
                "src/favicon.ico",
                "src/manifest.json",
                "src/background.js",
                "src/content.js"
              ],
              "scripts": [
                {
                  "input": "src/environments/environment.staging.js",
                  "bundleName": "environment",
                  "inject": false
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true,
              "outputHashing": "none",
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "**/*",
                  "input": "src/icons/local",
                  "output": "assets/icons"
                },
                "src/favicon.ico",
                "src/manifest.json",
                "src/background.js",
                "src/content.js"
              ],
              "scripts": [
                {
                  "input": "src/environments/environment.js",
                  "bundleName": "environment",
                  "inject": false
                }
              ]
            },
            "ci": {
              "progress": false
            }
          },
          "defaultConfiguration": "prod"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "extension-training:build:production"
            },
            "development": {
              "buildTarget": "extension-training:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "extension-training:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}