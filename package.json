{
  "name": "extension-training",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:chrome": "ng build --configuration production,chrome && npm run build:extension-scripts",
    "build:extension-scripts": "esbuild src/extension/service.ts --bundle --outfile=dist/extension-training/browser/extension/service.js --format=iife --platform=browser --target=es2022 && esbuild src/extension/content.ts --bundle --outfile=dist/extension-training/browser/extension/content.js --format=iife --platform=browser --target=es2022",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "17.1.0",
    "@angular/common": "17.1.0",
    "@angular/compiler": "17.1.0",
    "@angular/core": "17.1.0",
    "@angular/forms": "17.1.0",
    "@angular/platform-browser": "17.1.0",
    "@angular/platform-browser-dynamic": "17.1.0",
    "@angular/router": "17.1.0",
    "@fortawesome/fontawesome-free": "7.1.0",
    "rxjs": "7.8.0",
    "tslib": "2.3.0",
    "zone.js": "0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.1.0",
    "@angular-eslint/builder": "17.5.3",
    "@angular-eslint/eslint-plugin": "17.5.3",
    "@angular-eslint/eslint-plugin-template": "17.5.3",
    "@angular-eslint/schematics": "17.5.3",
    "@angular-eslint/template-parser": "17.5.3",
    "@angular/cli": "17.1.0",
    "@angular/compiler-cli": "17.1.0",
    "@tailwindcss/forms": "0.5.10",
    "@types/chrome": "0.1.27",
    "@types/jasmine": "5.1.0",
    "@typescript-eslint/eslint-plugin": "8.34.0",
    "@typescript-eslint/parser": "8.34.0",
    "autoprefixer": "10.4.20",
    "concurrently": "9.2.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsdoc": "51.0.1",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-prettier": "5.4.1",
    "fs-extra": "11.3.2",
    "jasmine-core": "5.1.0",
    "karma": "6.4.0",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "npm-run-all": "4.1.5",
    "onchange": "7.1.0",
    "postcss": "8.4.41",
    "tailwindcss": "3.4.17",
    "typescript": "5.2.2"
  }
}